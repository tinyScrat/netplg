@page "/orders"
@namespace MyApp.WebUI.Features.Orders
@using MyApp.Contracts.Orders
@inherits RxComponentBase
@inject OrdersViewModel VM

<PageTitle>Orders</PageTitle>

<EditOrder />

<RadzenDataGrid
    AllowFiltering="true"
    FilterMode="FilterMode.Simple"
    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
    LogicalFilterOperator="LogicalFilterOperator.And"

    AllowColumnResize="true"
    AllowAlternatingRows="false"
    AllowGrouping="false"
    AllowSorting="true"
    PageSize="@VM.OrdersData.PageSize"
    AllowPaging="true"
    PagerHorizontalAlign="HorizontalAlign.Left"
    Data="@VM.OrdersData.Items"
    TItem="OrderOverview"
    ColumnWidth="300px"
    ShowPagingSummary="true"
    IsLoading="@VM.IsLoading">
    <Columns>
        <RadzenDataGridColumn Property="@nameof(OrderOverview.CustomerName)" Title="Customer Name" Frozen="true" Width="160px" />
        <RadzenDataGridColumn Property="@nameof(OrderOverview.Amount)" Title="Amount" Width="160px" FormatString="{0:N2}" />
        <RadzenDataGridColumn Property="@nameof(OrderOverview.Status)" Title="Status" Width="160px" />
        <RadzenDataGridColumn Property="@nameof(OrderOverview.CreatedAt)" Title="Created At" Width="160px" FormatString="{0:d}" />
    </Columns>
</RadzenDataGrid>

@code {
    protected override void OnInitialized()
    {
        Bind(VM);
        VM.LoadOrders();
    }
}
